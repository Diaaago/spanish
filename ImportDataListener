private void addSuccessMessage(JobExecution jobExecution) {
    AtomicBoolean isPartial = new AtomicBoolean(false);

    String message = jobExecution.getStepExecutions().stream()
            .map(stepExecution -> buildStepMessage(stepExecution, isPartial))
            .collect(Collectors.joining("; "));

    message = appendFinalMessage(isPartial, message);
    this.addMessage(jobExecution, message);
}

private String buildStepMessage(StepExecution stepExecution, AtomicBoolean isPartial) {
    StringBuilder buffer = new StringBuilder();

    if (stepExecution.getStepName().equals(IMPORT_TASK_STEP)) {
        buffer.append(stepExecution.getWriteCount());
        buffer.append(" Tasks on");
        buffer.append(stepExecution.getReadCount());
        updatePartialFlag(stepExecution, isPartial);
    } else if (stepExecution.getStepName().equals(IMPORT_SUBPROCESS_STEP)) {
        buffer.append(stepExecution.getWriteCount());
        buffer.append(" Sub-process on");
        buffer.append(stepExecution.getReadCount());
        updatePartialFlag(stepExecution, isPartial);
    } else if (stepExecution.getStepName().equals(IMPORT_TEAM_STEP)) {
        buffer.append(stepExecution.getWriteCount());
        buffer.append(" Teams on");
        buffer.append(stepExecution.getReadCount());
        updatePartialFlag(stepExecution, isPartial);
    } else if (stepExecution.getStepName().equals(IMPORT_USER_STEP)) {
        buffer.append(stepExecution.getWriteCount());
        buffer.append(" Users on");
        buffer.append(stepExecution.getReadCount());
        updatePartialFlag(stepExecution, isPartial);
    }

    return buffer.toString();
}

private void updatePartialFlag(StepExecution stepExecution, AtomicBoolean isPartial) {
    if (isPartialStep(stepExecution)) {
        isPartial.set(true);
    }
}
