private void createBody(XSSFWorkbook workbook, Sheet sheet, int cellNumber,
                        List<Task> taskList, List<LocalDate> localDates) {

    final int[] rowNum = {10};
    LocalDateTime now = LocalDateTime.now(ZoneId.systemDefault());

    Map<SubProcess, List<Task>> sortedTaskMap = buildTaskMap(taskList);

    sortedTaskMap.forEach((subProcess, tasks) -> {
        for (Task task : tasks) {
            writeTaskRow(workbook, sheet, cellNumber, localDates, rowNum, now, subProcess, task);
        }
        rowNum[0]++;
    });
}
private Map<SubProcess, List<Task>> buildTaskMap(List<Task> taskList) {
    Map<SubProcess, List<Task>> listMap = taskList.stream()
            .filter(task -> task.getSubProcess() != null)
            .sorted(Comparator.comparing(Task::getExpectedEndDate))
            .collect(Collectors.groupingBy(Task::getSubProcess));

    List<Task> taskWithoutSubPList = taskList.stream()
            .filter(task -> task.getSubProcess() == null)
            .sorted(Comparator.comparing(Task::getExpectedEndDate))
            .collect(Collectors.toList());

    if (!taskWithoutSubPList.isEmpty()) {
        SubProcess subProcess = new SubProcess();
        subProcess.setName("");
        subProcess.setId(-99L);
        listMap.put(subProcess, taskWithoutSubPList);
    }

    Map<SubProcess, List<Task>> treeMap = new TreeMap<>(
            Comparator.comparing(o -> listMap.get(o).stream()
                    .findFirst()
                    .orElseThrow()
                    .getExpectedEndDate())
    );
    treeMap.putAll(listMap);
    return treeMap;
}
private void writeTaskRow(XSSFWorkbook workbook, Sheet sheet, int cellNumber,
                          List<LocalDate> localDates, int[] rowNum, LocalDateTime now,
                          SubProcess subProcess, Task task) {

    Row row = createRowAndCell(sheet, rowNum[0], 0, cellNumber);
    int col = 0;

    writeOnCell(row, col++, task.getProcess() != null ? subProcess.getName() : "");
    writeOnCell(row, col++, formatCalculation(task));
    writeOnCell(row, col++, task.getExpectedEndDate().format(DATE_CUSTOM_FORMATTER));
    writeOnCell(row, col++, task.getExpectedEndDate().format(HOUR_FORMATTER));
    writeOnCell(row, col++, task.getActor() != null ? task.getActor().getName() : "");
    writeOnCell(row, col++, task.getReceiver() != null ? task.getReceiver().getName() : "");
    writeOnCell(row, col++, task.getName());

    col = writeDependencyCells(row, col, task);

    writeOnCell(row, col++, formatComments(task.getComments()));
    fillCalendarBody(workbook, row, task, localDates, now, col);

    rowNum[0]++;
}
private String formatCalculation(Task task) {
    if (task.getCalculationType() == null) {
        return "";
    }

    String sign = task.getCalculation() > 0 ? "+" : "";
    if (task.getCalculationType() == CalculationType.CALENDAR_DAY) {
        return sign + task.getCalculation() + " calendar";
    }

    return sign + task.getCalculation() + " opening";
}
private int writeDependencyCells(Row row, int col, Task task) {
    if (task.getRelatedTask() != null) {
        writeOnCell(row, col++, task.getRelatedTask().getName());
        writeOnCell(row, col++, task.getRelatedTask().getActor() != null
                ? task.getRelatedTask().getActor().getName()
                : "");
        writeOnCell(row, col++, task.getRelatedTask().getSubProcess() != null
                ? task.getRelatedTask().getSubProcess().getName()
                : "");
        return col;
    }

    if (task.getRelatedTeam() != null) {
        writeOnCell(row, col++, "");
        writeOnCell(row, col++, task.getRelatedTeam().getName());
        writeOnCell(row, col++, "");
        return col;
    }

    writeOnCell(row, col++, "");
    writeOnCell(row, col++, "");
    writeOnCell(row, col++, "");
    return col;
}
