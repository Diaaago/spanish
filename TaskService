}
private void createAdminCommentIfPresent(TaskDTO taskDTO, Task task, Optional<User> optionalUser) {
    if (taskDTO.getAdminComment() == null) {
        return;
    }

    Comment comment = new Comment();
    comment.setDate(LocalDateTime.now());
    comment.setComment(taskDTO.getAdminComment());
    optionalUser.ifPresent(comment::setAuthor);
    comment.setTask(task);
    commentRepository.save(comment);
}
