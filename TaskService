private void createDependencyComment(Task task, Optional<User> optionalUser) {
    if (task.getRelatedTeam() == null && task.getRelatedTask() == null) {
        return;
    }

    Comment comment = new Comment();
    comment.setDate(LocalDateTime.now());

    if (task.getRelatedTeam() != null) {
        teamRepository.findById(task.getRelatedTeam().getId())
                .ifPresent(relatedTeam ->
                        comment.setComment(NEW_TEAM_DEPENDENCE + relatedTeam.getName()));
    } else {
        Task finalTask = task;
        taskRepository.findById(task.getRelatedTask().getId())
                .ifPresent(relatedTask -> {
                    comment.setComment(String.format(
                            NEW_TASK_DEPENDENCE,
                            relatedTask.getName(),
                            relatedTask.getActor() != null ? relatedTask.getActor().getName() : ""
                    ));
                    if (relatedTask.getStatus() != Status.DONE
                            && relatedTask.getStatus() != Status.DONE_WITH_DELAY) {
                        finalTask.setStatus(Status.WAITING_ACTION_THIRD_PARTY);
                        taskRepository.save(finalTask);
                    }
                });
    }

    optionalUser.ifPresent(comment::setAuthor);
    comment.setTask(task);
    commentRepository.save(comment);
}

