public TaskDTO updateTask(TaskDTO taskDTO, Long processId) {
    Task taskDatabase = taskRepository.findById(taskDTO.getId())
            .orElseThrow(() -> new NotFoundAlertException(""));

    Task task = taskMapper.toEntity(taskDTO);

    validateTaskUpdate(taskDatabase, task);

    updateSchedulingFields(taskDatabase, taskDTO, task, processId);
    updateBasicFields(taskDatabase, task);

    Optional<User> optionalUser = SecurityUtils.getCurrentUserLogin()
            .flatMap(userRepository::findOneByLogin);

    createDependencyComment(task, taskDatabase).ifPresent(comment -> {
        optionalUser.ifPresent(comment::setAuthor);
        comment.setTask(task);
        commentRepository.save(comment);
    });

    createAdminCommentIfPresent(taskDTO, task, optionalUser);

    taskDatabase.setRelatedTeam(task.getRelatedTeam());
    taskDatabase.setRelatedTask(task.getRelatedTask());

    return taskMapper.toDto(taskDatabase);
}
private void validateTaskUpdate(Task taskDatabase, Task task) {
    if (taskDatabase.getStatus() == Status.DONE
            || taskDatabase.getStatus() == Status.DONE_WITH_DELAY) {
        boolean isDependencyOfOtherTask = !taskRepository
                .findAllByRelatedTaskAndStatusIn(task, Arrays.asList(Status.DONE, Status.DONE_WITH_DELAY))
                .isEmpty();

        if (isDependencyOfOtherTask) {
            throw new BadRequestAlertException(ErrorConstants.INVALID_TASK_STATUS_KEY);
        }
    }

    if (task.getRelatedTask() != null) {
        taskRepository.findById(task.getRelatedTask().getId()).ifPresent(relatedTask -> {
            if (relatedTask.getStatus() == Status.DONE
                    || relatedTask.getStatus() == Status.DONE_WITH_DELAY) {
                taskDatabase.setStatus(task.getStatus());
            } else if (task.getStatus() == Status.UNDONE
                    || task.getStatus() == Status.WAITING_ACTION_THIRD_PARTY) {
                taskDatabase.setStatus(task.getStatus());
            } else {
                throw new BadRequestAlertException(ErrorConstants.INVALID_TASK_STATUS_KEY);
            }
        });
    } else {
        taskDatabase.setStatus(task.getStatus());
    }
}
private void updateSchedulingFields(Task taskDatabase, TaskDTO taskDTO, Task task, Long processId) {
    taskDatabase.setEndDate(taskDTO.getEndDate());
    taskDatabase.setCalculation(task.getCalculation());
    taskDatabase.setCalculationType(task.getCalculationType());

    if (taskDTO.getCalculationType() == CalculationType.CALENDAR_DAY) {
        taskDatabase.setExpectedEndDate(this.calculateCalendarDay(taskDatabase, processId));
    } else {
        taskDatabase.setExpectedEndDate(this.calculateWorkDay(taskDatabase, processId));
    }
}
private void updateBasicFields(Task taskDatabase, Task task) {
    taskDatabase.setReceiver(task.getReceiver());
    taskDatabase.setActor(task.getActor());
    taskDatabase.setName(task.getName());
    taskDatabase.setSubProcess(task.getSubProcess());
    taskDatabase.setDuplicated(task.isDuplicated());
}
