public TaskDTO createTask(TaskDTO taskDTO, Long processId) {
    Process process = processRepository.findById(processId)
            .orElseThrow(() -> new InternalServerErrorException(PROCESS_NOT_FOUND));

    Task task = taskMapper.toEntity(taskDTO);

    applyExpectedEndDate(task, processId);
    task.setProcess(process);

    task = taskRepository.save(task);

    Optional<User> optionalUser = SecurityUtils.getCurrentUserLogin()
            .flatMap(userRepository::findOneByLogin);

    createDependencyCommentIfNeeded(task, optionalUser);
    createAdminCommentIfPresent(taskDTO, task, optionalUser);

    return taskMapper.toDto(task);
}
private void applyExpectedEndDate(Task task, Long processId) {
    if (task.getCalculationType() == CalculationType.CALENDAR_DAY) {
        task.setExpectedEndDate(this.calculateCalendarDay(task, processId));
    } else {
        task.setExpectedEndDate(this.calculateWorkDay(task, processId));
    }
}
