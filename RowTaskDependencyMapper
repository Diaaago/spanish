private void validateRowData(
        String taskDependencyName,
        String teamDependencyName,
        String subprocessDependencyName,
        String taskName,
        String hour,
        Row row,
        int rowIndex) throws RowMappingException {

    if (StringUtils.isEmpty(taskDependencyName) && StringUtils.isEmpty(teamDependencyName)) {
        log.info("task has no dependency");
        throw new SkipDataException(new ValidationException("Empty line : "), row, rowIndex);
    }

    if (!StringUtils.isEmpty(taskDependencyName)
            && StringUtils.isEmpty(teamDependencyName)
            && StringUtils.isEmpty(subprocessDependencyName)) {
        throw new RowMappingException(
                new ValidationException(
                        "No team or subprocess dependence found for the task dependence : " + taskDependencyName),
                row,
                rowIndex
        );
    }

    if (StringUtils.isEmpty(taskName)) {
        log.info("ignoring task dependency for task with empty name");
        throw new SkipDataException(new ValidationException("Empty line : "), row, rowIndex);
    }

    if (StringUtils.isEmpty(hour)) {
        throw new RowMappingException(
                new ValidationException("Deadline Hour not found for task " + taskName),
                row,
                rowIndex
        );
    }
}
private List<Task> findTasks(String taskName, Team actor, LocalDateTime date, String subProcessName) {
    if (actor != null && !StringUtils.isEmpty(subProcessName)) {
        return taskRepository.findAllByNameAndProcessAndActorAndEndDateAndSubProcessName(
                taskName, process, actor, date, subProcessName);
    }

    if (actor != null) {
        return taskRepository.findAllByNameAndProcessAndActorAndEndDate(
                taskName, process, actor, date);
    }

    if (!StringUtils.isEmpty(subProcessName)) {
        return taskRepository.findAllByNameAndProcessAndSubProcessNameAndEndDate(
                taskName, process, subProcessName, date);
    }

    return taskRepository.findAllByNameAndProcessAndEndDate(
            taskName, process, date);
}
private void handleTaskDependency(
        Task task,
        String taskDependencyName,
        Team relatedTeam,
        String subprocessDependencyName,
        LocalDateTime date,
        Row row,
        int rowIndex) throws RowMappingException {

    LocalDateTime startEndDate = date.atStartOfDay();
    LocalDateTime endEndDate = date.atTime(LocalTime.MAX);

    List<Task> tasks = taskRepository.findAllByNameAndProcessAndActorAndSubProcessNameAndEndDateBetween(
            taskDependencyName,
            process,
            relatedTeam,
            subprocessDependencyName,
            startEndDate,
            endEndDate
    );

    if (tasks.size() != 1) {
        throw new RowMappingException(
                new ValidationException(
                        "No task or More than one Task dependence with name "
                                + taskDependencyName + " found"),
                row,
                rowIndex
        );
    }

    Task relatedTask = tasks.get(0);
    task.setRelatedTask(relatedTask);

    if (relatedTask.getStatus() == Status.DONE
            || relatedTask.getStatus() == Status.DONE_WITH_DELAY) {
        task.setStatus(Status.WAITING_ACTION_THIRD_PARTY);
    }
}
@Override
public Task mapRow(Row row, int rowIndex) throws RowMappingException {

    log.info("try to map row index: {} = {}", rowIndex, row.getSheet().getSheetName());

    String taskDependencyName = getString(row, TASK_DEPENDENCY_INDEX);
    String teamDependencyName = getString(row, TEAM_DEPENDENCY_INDEX);
    String subprocessDependencyName = getString(row, SUBPROCESS_DEPENDENCY_INDEX);
    String taskName = getString(row, NAME_INDEX);
    String providerTeamName = getString(row, PROVIDER_INDEX);
    String hour = getString(row, HOUR_INDEX);
    String subProcessName = getString(row, SUB_PROCESS_INDEX);

    validateRowData(
            taskDependencyName,
            teamDependencyName,
            subprocessDependencyName,
            taskName,
            hour,
            row,
            rowIndex
    );

    log.info("mapping task: {}", taskName);

    Team actor = null;
    if (!StringUtils.isEmpty(providerTeamName)) {
        actor = this.findTeamByName(providerTeamName, row, rowIndex);
    }

    LocalDateTime date;
    try {
        date = endDate
                .with(TemporalAdjusters.firstDayOfMonth())
                .atTime(LocalTime.parse(hour, HOUR_FORMAT));
    } catch (DateTimeParseException e) {
        throw new RowMappingException(e, row, rowIndex);
    }

    List<Task> tasks = findTasks(taskName, actor, date, subProcessName);

    if (tasks.size() != 1) {
        throw new RowMappingException(
                new ValidationException(
                        "More than one task with name " + taskName
                                + " found for this process and date. We ignore dependence for this task "),
                row,
                rowIndex
        );
    }

    Task task = tasks.get(0);
    Team relatedTeam = this.findTeamByName(teamDependencyName, row, rowIndex);

    if (!StringUtils.isEmpty(taskDependencyName)
            && !StringUtils.isEmpty(teamDependencyName)
            && !StringUtils.isEmpty(subprocessDependencyName)) {
        handleTaskDependency(
                task,
                taskDependencyName,
                relatedTeam,
                subprocessDependencyName,
                date,
                row,
                rowIndex
        );
    } else {
        task.setRelatedTeam(relatedTeam);
    }

    return task;
}
