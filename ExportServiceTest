@Test
void testWriteDependencyCells_withRelatedTask() throws Exception {
    XSSFWorkbook workbook = new XSSFWorkbook();
    Sheet sheet = workbook.createSheet();
    Row row = sheet.createRow(0);

    Actor actor = new Actor();
    actor.setName("Actor A");

    SubProcess subProcess = new SubProcess();
    subProcess.setName("SubProcess A");

    Task relatedTask = new Task();
    relatedTask.setName("Task A");
    relatedTask.setActor(actor);
    relatedTask.setSubProcess(subProcess);

    Task task = new Task();
    task.setRelatedTask(relatedTask);

    Method method = ExportService.class.getDeclaredMethod("writeDependencyCells", Row.class, int.class, Task.class);
    method.setAccessible(true);

    int result = (int) method.invoke(exportService, row, 0, task);

    assertEquals("Task A", row.getCell(0).getStringCellValue());
    assertEquals("Actor A", row.getCell(1).getStringCellValue());
    assertEquals("SubProcess A", row.getCell(2).getStringCellValue());
    assertEquals(3, result);
}
