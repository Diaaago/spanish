@Test
void testMergeRows_success() throws Exception {
    XSSFWorkbook workbook = new XSSFWorkbook();
    Sheet sheet = workbook.createSheet();

    Method method = ExportService.class.getDeclaredMethod("mergeRows", Sheet.class, int.class, int.class, int.class);
    method.setAccessible(true);

    method.invoke(exportService, sheet, 0, 2, 1);

    assertEquals(1, sheet.getNumMergedRegions());
    assertEquals(0, sheet.getMergedRegion(0).getFirstRow());
    assertEquals(2, sheet.getMergedRegion(0).getLastRow());
    assertEquals(1, sheet.getMergedRegion(0).getFirstColumn());
    assertEquals(1, sheet.getMergedRegion(0).getLastColumn());
}
@Test
void testMergeRows_illegalArgumentException() throws Exception {
    XSSFWorkbook workbook = new XSSFWorkbook();
